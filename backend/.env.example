OPENAI_API_KEY=your_openrouter_or_openai_key_here
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_MODEL_NAME=openrouter/google/gemini-2.0-flash-lite:free
OPENAI_MAX_TOKENS=1200

# Optional but recommended for LangGraph tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=MuseAI-LangGraph

# Optional: override the Python executable used to launch the stdio MCP server
MUSEAI_MCP_PYTHON=
